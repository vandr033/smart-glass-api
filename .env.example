# Core application settings
APP_NAME=SaaS Base API
BETTER_AUTH_SECRET=development-better-auth-secret-change-me
BETTER_AUTH_URL=http://localhost:4000
DATABASE_URL=mysql://user:password@localhost:3306/app_db
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info
NODE_ENV=development
PORT=4000

# Email sender identity
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=SaaS Base Project

# Optional SMTP transport settings. Uncomment to enable outbound email delivery.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=smtp-user
# SMTP_PASS=smtp-password

# Optional seed overrides used by `npm run db:seed`
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_APP_NAME=ERP Foundation
SEED_SUPPORT_EMAIL=support@example.com
SEED_TIMEZONE=America/La_Paz
SEED_DATE_FORMAT=YYYY-MM-DD
SEED_SENDER_NAME=ERP Foundation
SEED_SENDER_EMAIL=no-reply@example.com
SEED_PRIMARY_COLOR=#1f2937
SEED_LOGO=
