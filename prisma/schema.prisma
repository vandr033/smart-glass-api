  createdAt           DateTime                   @default(now()) @map("created_at")
  updatedAt           DateTime                   @updatedAt @map("updated_at")
  purchaseRequest     PurchaseRequest            @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  material            Material                   @relation(fields: [materialId], references: [id], onDelete: Restrict)
  preferredSupplier   Supplier?                  @relation("PurchaseRequestItemPreferredSupplier", fields: [preferredSupplierId], references: [id], onDelete: SetNull)
  selectedSupplier    Supplier?                  @relation("PurchaseRequestItemSelectedSupplier", fields: [selectedSupplierId], references: [id], onDelete: SetNull)
  comparisonOptions   SupplierComparisonOption[]

  @@index([purchaseRequestId, status])
  @@index([materialId])
  @@index([preferredSupplierId])
  @@index([selectedSupplierId])
  @@map("purchase_request_items")
}

model SupplierComparison {
  id                      String                     @id @default(uuid()) @db.Char(36)
  purchaseRequestId       String                     @map("purchase_request_id") @db.Char(36)
  status                  SupplierComparisonStatus   @default(DRAFT)
  scoringConfigId         String?                    @map("scoring_config_id") @db.Char(36)
  resultJson              Json?                      @map("result_json")
  selectedCombinationJson Json?                      @map("selected_combination_json")
  createdByUserId         String?                    @map("created_by_user_id") @db.Char(36)
  approvedByUserId        String?                    @map("approved_by_user_id") @db.Char(36)
  approvedAt              DateTime?                  @map("approved_at")
  createdAt               DateTime                   @default(now()) @map("created_at")
  updatedAt               DateTime                   @updatedAt @map("updated_at")
  purchaseRequest         PurchaseRequest            @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  scoringConfig           SupplierScoringConfig?     @relation(fields: [scoringConfigId], references: [id], onDelete: SetNull)
  createdByUser           User?                      @relation("SupplierComparisonCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUser          User?                      @relation("SupplierComparisonApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  options                 SupplierComparisonOption[]

  @@index([purchaseRequestId, status])
  @@index([scoringConfigId])
  @@index([createdByUserId])
  @@index([approvedByUserId])
  @@map("supplier_comparisons")
}

model SupplierComparisonOption {
  id                    String              @id @default(uuid()) @db.Char(36)
  comparisonId          String              @map("comparison_id") @db.Char(36)
  purchaseRequestItemId String              @map("purchase_request_item_id") @db.Char(36)
  supplierId            String              @map("supplier_id") @db.Char(36)
  materialId            String              @map("material_id") @db.Char(36)
  unitPrice             Decimal?            @map("unit_price") @db.Decimal(14, 4)
  totalPrice            Decimal?            @map("total_price") @db.Decimal(14, 4)
  deliveryDays          Int?                @map("delivery_days")
  availableCredit       Boolean?            @map("available_credit")
  supplierScore         Decimal?            @map("supplier_score") @db.Decimal(9, 4)
  finalScore            Decimal?            @map("final_score") @db.Decimal(9, 4)
  scoreBreakdownJson    Json?               @map("score_breakdown_json")
  isSelected            Boolean             @default(false) @map("is_selected")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  comparison            SupplierComparison  @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  purchaseRequestItem   PurchaseRequestItem @relation(fields: [purchaseRequestItemId], references: [id], onDelete: Cascade)
  supplier              Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  material              Material            @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([comparisonId, isSelected])
  @@index([purchaseRequestItemId])
  @@index([supplierId])
  @@index([materialId])
  @@map("supplier_comparison_options")
}

model PurchaseOrder {
  id                   String              @id @default(uuid()) @db.Char(36)
  code                 String              @unique @db.VarChar(100)
  supplierId           String              @map("supplier_id") @db.Char(36)
  purchaseRequestId    String?             @map("purchase_request_id") @db.Char(36)
  status               PurchaseOrderStatus @default(DRAFT)
  orderDate            DateTime            @map("order_date")
  expectedDeliveryDate DateTime?           @map("expected_delivery_date")
  currency             String              @default("BOB") @db.VarChar(16)
  subtotal             Decimal             @default(0) @db.Decimal(14, 4)
  discountAmount       Decimal             @default(0) @map("discount_amount") @db.Decimal(14, 4)
  taxAmount            Decimal             @default(0) @map("tax_amount") @db.Decimal(14, 4)
  total                Decimal             @default(0) @db.Decimal(14, 4)
  notes                String?             @db.Text
  createdByUserId      String?             @map("created_by_user_id") @db.Char(36)
  sentAt               DateTime?           @map("sent_at")
  confirmedAt          DateTime?           @map("confirmed_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  deletedAt            DateTime?           @map("deleted_at")
  supplier             Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseRequest      PurchaseRequest?    @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  createdByUser        User?               @relation("PurchaseOrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items                PurchaseOrderItem[]
  receipts             PurchaseReceipt[]

  @@index([supplierId, status, deletedAt])
  @@index([purchaseRequestId])
  @@index([createdByUserId])
  @@index([orderDate, deletedAt])
  @@index([expectedDeliveryDate, deletedAt])
  @@index([deletedAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String                @id @default(uuid()) @db.Char(36)
  purchaseOrderId  String                @map("purchase_order_id") @db.Char(36)
  materialId       String                @map("material_id") @db.Char(36)
  description      String?               @db.Text
  quantity         Decimal               @db.Decimal(14, 4)
  unit             MaterialUnit
  unitPrice        Decimal               @map("unit_price") @db.Decimal(14, 4)
  totalPrice       Decimal               @map("total_price") @db.Decimal(14, 4)
  receivedQuantity Decimal               @default(0) @map("received_quantity") @db.Decimal(14, 4)
  metadataJson     Json?                 @map("metadata_json")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  purchaseOrder    PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  material         Material              @relation(fields: [materialId], references: [id], onDelete: Restrict)
  receiptItems     PurchaseReceiptItem[]

  @@index([purchaseOrderId])
  @@index([materialId])
  @@map("purchase_order_items")
}

model PurchaseReceipt {
  id               String                @id @default(uuid()) @db.Char(36)
  purchaseOrderId  String                @map("purchase_order_id") @db.Char(36)
  code             String                @unique @db.VarChar(100)
  warehouseId      String                @map("warehouse_id") @db.Char(36)
  receivedByUserId String?               @map("received_by_user_id") @db.Char(36)
  receivedAt       DateTime              @map("received_at")
  notes            String?               @db.Text
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  purchaseOrder    PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  warehouse        Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  receivedByUser   User?                 @relation("PurchaseReceiptReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  items            PurchaseReceiptItem[]

  @@index([purchaseOrderId, receivedAt])
  @@index([warehouseId, receivedAt])
  @@index([receivedByUserId])
  @@map("purchase_receipts")
}

model PurchaseReceiptItem {
  id                  String            @id @default(uuid()) @db.Char(36)
  purchaseReceiptId   String            @map("purchase_receipt_id") @db.Char(36)
  purchaseOrderItemId String            @map("purchase_order_item_id") @db.Char(36)
  materialId          String            @map("material_id") @db.Char(36)
  receivedQuantity    Decimal           @map("received_quantity") @db.Decimal(14, 4)
  unit                MaterialUnit
  batchNumber         String?           @map("batch_number") @db.VarChar(100)
  locationCode        String?           @map("location_code") @db.VarChar(100)
  notes               String?           @db.Text
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  purchaseReceipt     PurchaseReceipt   @relation(fields: [purchaseReceiptId], references: [id], onDelete: Cascade)
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Restrict)
  material            Material          @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([purchaseReceiptId])
  @@index([purchaseOrderItemId])
  @@index([materialId])
  @@map("purchase_receipt_items")
}

model SupplierCategory {
  id             String                       @id @default(uuid()) @db.Char(36)
  name           String                       @unique @db.VarChar(191)
  description    String?                      @db.VarChar(255)
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")
  assignments    SupplierCategoryAssignment[]
  scoringConfigs SupplierScoringConfig[]

  @@map("supplier_categories")
}

model SupplierCategoryAssignment {
  id         String           @id @default(uuid()) @db.Char(36)
  supplierId String           @map("supplier_id") @db.Char(36)
  categoryId String           @map("category_id") @db.Char(36)
  createdAt  DateTime         @default(now()) @map("created_at")
  supplier   Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category   SupplierCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([supplierId, categoryId])
  @@index([categoryId])
  @@map("supplier_category_assignments")
}

model SupplierContact {
  id         String   @id @default(uuid()) @db.Char(36)
  supplierId String   @map("supplier_id") @db.Char(36)
  name       String   @db.VarChar(191)
  position   String?  @db.VarChar(191)
  phone      String?  @db.VarChar(50)
  whatsapp   String?  @db.VarChar(50)
  email      String?  @db.VarChar(191)
  isPrimary  Boolean  @default(false) @map("is_primary")
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, isPrimary])
  @@map("supplier_contacts")
}

model SupplierScoringCriterion {
  id            String                        @id @default(uuid()) @db.Char(36)
  key           String                        @unique @db.VarChar(100)
  label         String                        @db.VarChar(191)
  description   String?                       @db.VarChar(255)
  isEnabled     Boolean                       @default(true) @map("is_enabled")
  sortOrder     Int                           @default(0) @map("sort_order")
  createdAt     DateTime                      @default(now()) @map("created_at")
  updatedAt     DateTime                      @updatedAt @map("updated_at")
  configWeights SupplierScoringConfigWeight[]

  @@index([isEnabled, sortOrder])
  @@map("supplier_scoring_criteria")
}

model SupplierScoringConfig {
  id          String                        @id @default(uuid()) @db.Char(36)
  name        String                        @db.VarChar(191)
  scope       SupplierScoringScope
  categoryId  String?                       @map("category_id") @db.Char(36)
  isDefault   Boolean                       @default(false) @map("is_default")
  isActive    Boolean                       @default(true) @map("is_active")
  createdAt   DateTime                      @default(now()) @map("created_at")
  updatedAt   DateTime                      @updatedAt @map("updated_at")
  category    SupplierCategory?             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  weights     SupplierScoringConfigWeight[]
  comparisons SupplierComparison[]

  @@index([scope, isActive, isDefault])
  @@index([categoryId, isActive])
  @@map("supplier_scoring_configs")
}

model SupplierScoringConfigWeight {
  id          String                   @id @default(uuid()) @db.Char(36)
  configId    String                   @map("config_id") @db.Char(36)
  criterionId String                   @map("criterion_id") @db.Char(36)
  weight      Decimal                  @db.Decimal(5, 2)
  createdAt   DateTime                 @default(now()) @map("created_at")
  config      SupplierScoringConfig    @relation(fields: [configId], references: [id], onDelete: Cascade)
  criterion   SupplierScoringCriterion @relation(fields: [criterionId], references: [id], onDelete: Restrict)

  @@unique([configId, criterionId])
  @@index([criterionId])
  @@map("supplier_scoring_config_weights")
}
