model User {
  id                              String                      @id @default(uuid()) @db.Char(36)
  name                            String                      @db.VarChar(191)
  email                           String                      @unique @db.VarChar(191)
  password                        String?                     @db.VarChar(255)
  avatar                          String?                     @db.VarChar(255)
  isActive                        Boolean                     @default(true) @map("is_active")
  emailVerified                   Boolean                     @default(false) @map("email_verified")
  lastLoginAt                     DateTime?                   @map("last_login_at")
  createdAt                       DateTime                    @default(now()) @map("created_at")
  updatedAt                       DateTime                    @updatedAt @map("updated_at")
  deletedAt                       DateTime?                   @map("deleted_at")
  accounts                        Account[]
  sessions                        Session[]
  createdInvites                  Invitation[]                @relation("InvitationCreatedBy")
  userRoles                       UserRole[]
  notifications                   Notification[]
  activityLogs                    ActivityLog[]
  auditLogs                       AuditLog[]                  @relation("AuditLogActor")
  importedPriceLists              PriceListImport[]           @relation("PriceListImportedBy")
  approvedPriceLists              PriceListImport[]           @relation("PriceListApprovedBy")
  responsibleProjects             Project[]                   @relation("ProjectResponsibleUser")
  salesProjects                   Project[]                   @relation("ProjectSalesUser")
  changedProjectStatuses          ProjectStatusHistory[]      @relation("ProjectStatusHistoryChangedBy")
  projectNotes                    ProjectNote[]
  uploadedProjectAttachments      ProjectAttachment[]         @relation("ProjectAttachmentUploadedBy")
  measuredProjects                ProjectMeasurement[]        @relation("ProjectMeasurementMeasuredBy")
  createdProductTemplates         ProductTemplate[]           @relation("ProductTemplateCreatedBy")
  createdProductTemplateVersions  ProductTemplateVersion[]    @relation("ProductTemplateVersionCreatedBy")
  productTemplateSimulations      ProductTemplateSimulation[] @relation("ProductTemplateSimulationBy")
  createdQuotations               Quotation[]                 @relation("QuotationCreatedBy")
  approvedQuotations              Quotation[]                 @relation("QuotationApprovedBy")
  createdQuotationVersions        QuotationVersion[]          @relation("QuotationVersionCreatedBy")
  requestedQuotationApprovals     QuotationApproval[]         @relation("QuotationApprovalRequestedBy")
  assignedQuotationApprovals      QuotationApproval[]         @relation("QuotationApprovalApprover")
  decidedQuotationApprovals       QuotationApproval[]         @relation("QuotationApprovalDecidedBy")
  changedQuotationStatuses        QuotationStatusHistory[]    @relation("QuotationStatusHistoryChangedBy")
  generatedQuotationPdfExports    QuotationPdfExport[]        @relation("QuotationPdfExportGeneratedBy")
  inventoryMovementsCreated       InventoryMovement[]         @relation("InventoryMovementCreatedBy")
  inventoryReservationsCreated    InventoryReservation[]      @relation("InventoryReservationCreatedBy")
  reportedDamagedMaterials        DamagedMaterial[]           @relation("DamagedMaterialReportedBy")
  createdCuttingOptimizationRuns  CuttingOptimizationRun[]    @relation("CuttingOptimizationRunCreatedBy")
  approvedCuttingOptimizationRuns CuttingOptimizationRun[]    @relation("CuttingOptimizationRunApprovedBy")
  createdProfileOptimizationRuns  ProfileOptimizationRun[]    @relation("ProfileOptimizationRunCreatedBy")
  requestedPurchaseRequests       PurchaseRequest[]           @relation("PurchaseRequestRequestedBy")
  approvedPurchaseRequests        PurchaseRequest[]           @relation("PurchaseRequestApprovedBy")
  createdSupplierComparisons      SupplierComparison[]        @relation("SupplierComparisonCreatedBy")
  approvedSupplierComparisons     SupplierComparison[]        @relation("SupplierComparisonApprovedBy")
  createdPurchaseOrders           PurchaseOrder[]             @relation("PurchaseOrderCreatedBy")
  receivedPurchaseReceipts        PurchaseReceipt[]           @relation("PurchaseReceiptReceivedBy")
  assignedProductionJobs          ProductionJob[]             @relation("ProductionJobAssignedTo")
  createdProductionJobs           ProductionJob[]             @relation("ProductionJobCreatedBy")
  assignedProductionTasks         ProductionTask[]            @relation("ProductionTaskAssignedTo")
  consumedMaterials               MaterialConsumption[]       @relation("MaterialConsumptionConsumedBy")
  changedProductionStatuses       ProductionStatusHistory[]   @relation("ProductionStatusHistoryChangedBy")
  checkedQualityChecks            QualityCheck[]              @relation("QualityCheckCheckedBy")
  createdInstallationOrders       InstallationOrder[]         @relation("InstallationOrderCreatedBy")
  supervisedInstallationOrders    InstallationOrder[]         @relation("InstallationOrderSupervisor")
  supervisedInstallationTeams     InstallationTeam[]          @relation("InstallationTeamSupervisor")
  installationTeamMemberships     InstallationTeamMember[]    @relation("InstallationTeamMemberUser")
  completedInstallationTasks      InstallationTask[]          @relation("InstallationTaskCompletedBy")
  uploadedInstallationEvidence    InstallationEvidence[]      @relation("InstallationEvidenceUploadedBy")
  reportedInstallationIssues      InstallationIssue[]         @relation("InstallationIssueReportedBy")
  resolvedInstallationIssues      InstallationIssue[]         @relation("InstallationIssueResolvedBy")
  changedInstallationStatuses     InstallationStatusHistory[] @relation("InstallationStatusHistoryChangedBy")
  createdMeasurementRequests      MeasurementRequest[]        @relation("MeasurementRequestCreatedBy")
  assignedMeasurementRequests     MeasurementRequest[]        @relation("MeasurementRequestTechnician")
  approvedMeasurementRequests     MeasurementRequest[]        @relation("MeasurementRequestApprovedBy")
  technicalVisits                 MeasurementVisit[]          @relation("MeasurementVisitTechnician")
  uploadedMeasurementEvidence     MeasurementEvidence[]       @relation("MeasurementEvidenceUploadedBy")
  createdTechnicalObservations    TechnicalObservation[]      @relation("TechnicalObservationCreatedBy")
  resolvedTechnicalObservations   TechnicalObservation[]      @relation("TechnicalObservationResolvedBy")
  changedMeasurementStatuses      MeasurementStatusHistory[]  @relation("MeasurementStatusHistoryChangedBy")

  @@index([deletedAt])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Char(36)
  name            String           @unique @db.VarChar(191)
  description     String?          @db.VarChar(255)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  invitations     Invitation[]

  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Char(36)
  name            String           @unique @db.VarChar(191)
  description     String?          @db.VarChar(255)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  rolePermissions RolePermission[]

  @@index([deletedAt])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  roleId    String   @map("role_id") @db.Char(36)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Char(36)
  roleId       String     @map("role_id") @db.Char(36)
  permissionId String     @map("permission_id") @db.Char(36)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Invitation {
  id          String    @id @default(uuid()) @db.Char(36)
  email       String    @db.VarChar(191)
  token       String    @unique @db.VarChar(191)
  roleId      String    @map("role_id") @db.Char(36)
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdById String    @map("created_by") @db.Char(36)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdBy   User      @relation("InvitationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([email])
  @@index([roleId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("invitations")
}

model Setting {
  id           String    @id @default(uuid()) @db.Char(36)
  appName      String    @map("app_name") @db.VarChar(191)
  logo         String?   @db.VarChar(255)
  primaryColor String?   @map("primary_color") @db.VarChar(32)
  supportEmail String    @map("support_email") @db.VarChar(191)
  timezone     String    @db.VarChar(100)
  dateFormat   String    @map("date_format") @db.VarChar(50)
  senderName   String    @map("sender_name") @db.VarChar(191)
  senderEmail  String    @map("sender_email") @db.VarChar(191)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("settings")
}

model Notification {
  id        String           @id @default(uuid()) @db.Char(36)
  userId    String           @map("user_id") @db.Char(36)
  title     String           @db.VarChar(191)
  message   String           @db.Text
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

model ModuleRecord {
  id          String    @id @default(uuid()) @db.Char(36)
  moduleKey   String    @map("module_key") @db.VarChar(100)
  name        String    @db.VarChar(191)
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([moduleKey, deletedAt])
  @@index([moduleKey, isActive])
  @@index([moduleKey, createdAt])
  @@map("module_records")
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String?  @map("user_id") @db.Char(36)
  action     String   @db.VarChar(191)
  entityType String   @map("entity_type") @db.VarChar(191)
  entityId   String?  @map("entity_id") @db.Char(36)
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Char(36)
  actorUserId  String?  @map("changed_by") @db.Char(36)
  action       String   @default("Updated") @db.VarChar(191)
  entityType   String   @map("entity_type") @db.VarChar(191)
  entityId     String?  @map("entity_id") @db.Char(36)
  beforeJson   Json?    @map("old_values")
  afterJson    Json?    @map("new_values")
  metadataJson Json?    @map("metadata_json")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  actorUser    User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id          String   @id @default(uuid()) @db.Char(36)
  key         String   @unique @db.VarChar(191)
  valueJson   Json     @map("value_json")
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("system_settings")
}

model ModuleRegistry {
  id                 String   @id @default(uuid()) @db.Char(36)
  key                String   @unique @db.VarChar(100)
  label              String   @db.VarChar(191)
  description        String?  @db.Text
  route              String   @db.VarChar(255)
  icon               String?  @db.VarChar(100)
  sortOrder          Int      @map("sort_order")
  isEnabled          Boolean  @default(true) @map("is_enabled")
  requiredPermission String?  @map("required_permission") @db.VarChar(191)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([isEnabled, sortOrder])
  @@map("module_registry")
}

model Session {
  id        String   @id @default(uuid()) @db.Char(36)
  expiresAt DateTime @map("expires_at")
  token     String   @unique @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(255)
  userId    String   @map("user_id") @db.Char(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid()) @db.Char(36)
  accountId             String    @map("account_id") @db.VarChar(191)
  providerId            String    @map("provider_id") @db.VarChar(191)
  userId                String    @map("user_id") @db.Char(36)
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @db.VarChar(255)
  password              String?   @db.VarChar(255)
